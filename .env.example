# Anita environment configuration
# ---------------------------------
# Copy this file to `.env` and fill in your credentials.
# `.env` is git-ignored and auto-loaded by Anita at runtime.
#
# Docs: https://github.com/timpara/anita#configuration

# Required when using the default OpenAI TTS provider
# or the OpenAI (DALL·E / gpt-image-1) image provider.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required when using the ElevenLabs TTS provider (`--tts elevenlabs`).
# Optional otherwise. Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
